# Python cache
__pycache__/
*.py[cod]
*$py.class

# Build / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Editors / IDEs
.vscode/
.idea/

# Environment variables / secrets
.env
.env.*
*.pem
*.key

# Temporary files
tmp/
temp/
*.tmp

# Python testing / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local outputs you may not want to track
outputs/
checkpoints/
